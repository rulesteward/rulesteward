#
# 90-deny-all-fallback.rules
#
# Terminal fallback rules. These are the last rules evaluated in fagenrules
# load order. Any subject/object combination not matched by an earlier
# allow rule is denied here.
#
# IMPORTANT: Do not add allow rules below these deny-all lines. An allow
# rule placed after a deny-all that subsumes it will be unreachable and
# will trigger the fapd-W01 (same file) or fapd-W04 (cross-file) lint
# codes. All allow carve-outs belong in earlier-loading files (10-xx
# through 80-xx).
#
# Tier: 90 - terminal fallback deny rules (load last).
#
# License: BSD-3-Clause (see LICENSE in this directory)
#

# Deny and audit any operation (open or execute) not matched by an earlier
# allow rule. perm=any covers both access modes in a single terminal rule, and
# the audit variant logs every blocked attempt so administrators can identify
# processes that need a carve-out.
#
# For a default-OPEN posture (deny execution but allow file reads), narrow this
# to perm=execute and add the corresponding allow perm=open carve-out in an
# earlier-loading file (10-xx through 80-xx), never below this line.
deny_audit perm=any all : all
