## This file is automatically generated from /etc/audit/rules.d
# Watch-vs-syscall EQUIVALENCE trap (f3 section 2.2). The SAME audit intent
# (record write+attr access to /etc/passwd) expressed as a -w watch.
# auditctl(8): a -w file watch is 'almost the same as using the -F path option
# on a syscall rule'; -p wa maps to AUDIT_PERM_WRITE+AUDIT_PERM_ATTR
# (auditctl.c:341-347). This is the file-watch sugar form.
-w /etc/passwd -p wa -k passwd_watch
# The EQUIVALENT desugared syscall form of the same intent. -F path=/etc/passwd
# (fieldtab.h path=AUDIT_WATCH) + -F perm=wa (perm=AUDIT_PERM, permtab.h: w+a
# syscall groups). Per f3 section 2.2 a -w watch desugars to exactly this
# path/perm exit-list rule. The cost model MUST price these two forms the SAME.
# perm equality fields single-quoted-safe; path/perm are = ops (f3 section 1).
-a always,exit -F path=/etc/passwd -F perm=wa -k passwd_syscall
