    "method": "grammar-only",
    "verdict": "valid",
    "log": "validation.log"
  },
  "rules": [
    {
      "line": "-w /etc/passwd -p wa -k identity",
      "kind": "watch",
      "tier": "MEDIUM",
      "direction": "additive",
      "key": "identity",
      "bytes_per_event": 1200,
      "rate_band": {
        "low": 10,
        "typical": 500,
        "high": 5000
      }
    },
    {
