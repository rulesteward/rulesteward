## This file is automatically generated from /etc/audit/rules.d
# Arch-paired b64 + b32 (f3 section 2.4; arch b64/b32 special values libaudit.c:1419).
# The SAME syscall rule must be declared once per arch to catch both 64-bit and
# 32-bit binaries (a 32-bit process makes 32-bit syscalls, matched only by arch=b32).
# The two lines are INTENTIONAL (32+64 coverage), NOT a redundant duplicate. A model
# that dedups them loses the 32-bit coverage; one that double-counts over-states.
-a always,exit -F arch=b64 -S execve -F 'auid>=1000' -F 'auid!=unset' -k execve_cmd
-a always,exit -F arch=b32 -S execve -F 'auid>=1000' -F 'auid!=unset' -k execve_cmd
