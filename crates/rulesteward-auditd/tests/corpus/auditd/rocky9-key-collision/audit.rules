## This file is automatically generated from /etc/audit/rules.d
# Key collision (catalog #31): two DIFFERENT rules sharing one -k key. Per-key
# aggregation (f3 section 7 item 1: group events by key=) must attribute each rule's
# volume correctly and NOT conflate the two rules as a single rule. Both events carry
# key=access but come from different syscalls with very different volumes.
#
# Rule 1: unrestricted execve (HIGH), key=access.
-a always,exit -S execve -k access
# Rule 2: a rare module-load syscall (LOW), SAME key=access.
-a always,exit -S init_module -S finit_module -k access
