## This file is automatically generated from /etc/audit/rules.d
# Field-comparison (-C) + many-field (-F) parser stress (f3 section 2.3).
# -C f1 op f2 is a field_compare (fieldtab.h:63 field_compare). -C uid!=euid maps
# to AUDIT_COMPARE_UID_TO_EUID (libaudit.c:1158), flagging a uid/euid mismatch
# (privilege transition). Up to 64 -F fields AND together per rule (auditctl(8)).
# All comparison fields single-quoted per f3 section 1.
#
# Rule A: field-comparison rule (uid != euid on execve).
-a always,exit -S execve -C 'uid!=euid' -k priv_escalation
# Rule B: a many-F AND'ed syscall rule (10 fields, well under the 64 limit).
-a always,exit -S openat -F 'auid>=1000' -F 'auid!=unset' -F 'success=1' -F 'arch=b64' -F 'exit>=0' -F 'uid!=root' -F 'gid!=0' -F 'a0=0' -F 'sessionid!=unset' -k narrowed_openat
