## This file is automatically generated from /etc/audit/rules.d
# Multiple -S OR'd (f3 section 2.3: multiple -S OR together). One rule naming
# several syscalls fires on ANY of them, so its volume is the SUM over the named
# syscalls, not one. A naive 'one rule = one syscall' model understates by ~3x here.
-a always,exit -S open -S openat -S openat2 -k file_open
