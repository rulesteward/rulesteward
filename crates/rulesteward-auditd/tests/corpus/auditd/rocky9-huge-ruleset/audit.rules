# --- syscall rules (a handful HIGH/MEDIUM that should DOMINATE ranking) ---
-a always,exit -S execve -k execve_all
-a always,exit -S openat -F 'auid>=1000' -F 'auid!=unset' -k file_access
-a always,exit -S connect -k network
-a always,exit -S adjtimex -S settimeofday -k time_change
-a always,exit -S init_module -S finit_module -S delete_module -k modules
-a always,exit -S mount -k mounts
-a always,exit -S ptrace -k tracing
-a always,exit -F arch=b64 -S setuid -S setgid -F 'auid>=1000' -k identity_change
