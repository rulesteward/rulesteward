## This file is automatically generated from /etc/audit/rules.d
# No -k key rules (f3 section 7 item 2: unattributable / low-value flag territory).
# A rule with no -k still GENERATES events; it just cannot be grouped by key in the
# --from-log per-key aggregation. The cost model MUST still tier these (the missing
# key is a noise-reduction signal, NOT a parse error). Comparison fields quoted.
#
# Unrestricted execve, NO key (HIGH but unattributable).
-a always,exit -S execve
# A file watch, NO key.
-w /etc/shadow -p wa
# A narrowed syscall, NO key.
-a always,exit -S openat -F 'auid>=1000' -F 'auid!=unset'
