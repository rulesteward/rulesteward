## This file is automatically generated from /etc/audit/rules.d
# filesystem filter-list rule (f3 section 2.3; flagtab.h:25-29 AUDIT_FILTER_FS
# 'filesystem'). Distinct from the 'exit' list: the filesystem list matches on
# fstype, filtering by filesystem TYPE rather than syscall exit. A valid, distinct
# filter list a naive parser that only knows 'exit'/'task' may not recognize.
-a always,filesystem -F fstype=ext4 -F 'auid>=1000' -F 'auid!=unset' -k fs_ext4
