## This file is automatically generated from /etc/audit/rules.d
# Perm-expansion breadth trap (f3 §2.4, permtab.h). A -w watch's -p chars map to
# whole syscall GROUPS, not one syscall:
#   -p r -> AUDIT_PERM_READ : 21 syscalls (readlink,quotactl,...,open,openat,openat2,
#           stat,lstat,fstat,newfstatat,statx,getxattr,listxattr,...)
#   -p w -> AUDIT_PERM_WRITE: 26 syscalls (rename,mkdir,rmdir,creat,link,unlink,...,
#           truncate,bind,fallocate,open,openat,openat2)
# A naive "one rule = one syscall" cost model understates this rule's breadth ~20x+.
-w /etc/passwd -p r -k passwd_read
-w /etc/passwd -p w -k passwd_write
