## This file is automatically generated from /etc/audit/rules.d
# Prepend (-A) vs append (-a) ordering (f3 section 2.3, catalog #28). -A inserts a
# rule at the FRONT of the list; -a appends. Load order = match order, first match
# wins. Here an -A never rule is PREPENDED so it sits in front of an earlier-listed
# -a always rule on the same syscall, making it suppress despite appearing second
# textually. The cost model must order by INSERTION (-A front, -a back), not by line.
#
# Textual line 1: append an always rule (goes to the BACK of the list).
-a always,exit -S execve -k execve_all
# Textual line 2: PREPEND a never rule (goes to the FRONT, before the always above).
-A exit,never -S execve -F 'uid=0'
